# Copy to .env and fill in values — never commit .env to git

ANTHROPIC_API_KEY=your_key_here
VIRUSTOTAL_API_KEY=your_key_here
ABUSEIPDB_API_KEY=your_key_here

# Case directories (absolute paths on SIFT VM)
CASE_DIR=/cases
EXPORTS_DIR=./exports
ANALYSIS_DIR=./analysis

# SIFT tool paths (defaults match SIFT Workstation)
VOLATILITY_CMD=python3 -m volatility3
LOG2TIMELINE_CMD=log2timeline.py
PSORT_CMD=psort.py
FLS_CMD=fls
MMLS_CMD=mmls
ICAT_CMD=icat
YARA_CMD=yara
EZ_TOOLS_DIR=/opt/zimmermantools
HAYABUSA_CMD=hayabusa

# RAG settings
RAG_DB_PATH=./rag/db
EMBED_MODEL=all-MiniLM-L6-v2

# Execution limits
MAX_TOOL_TIMEOUT=300
MAX_ITERATIONS=10

# MCP transport (client-agnostic). Default 'stdio' (Claude Code/Desktop spawn the server).
# Set to 'sse' or 'streamable-http' to expose an HTTP endpoint any MCP client / remote agent
# / gateway can connect to. Host/port apply to the HTTP transports.
DEEPSIFT_MCP_TRANSPORT=stdio
DEEPSIFT_MCP_HOST=127.0.0.1
DEEPSIFT_MCP_PORT=8000

# Agent token-scale: max chars of a single parsed tool result handed to the LLM
# (raw evidence is never sent to the model — only the parser's capped summary).
AGENT_TOOL_RESULT_CHARS=12000

# Tamper-EVIDENCE: an externally-held secret that HMAC-signs the chain-of-custody log.
# Set this (and keep it OFF the evidence host) to make the audit chain forgery-resistant
# — an attacker who rewrites the log cannot recompute valid signatures without the key.
# If unset, the SHA-256 hash chain still DETECTS naive tampering.
DEEPSIFT_AUDIT_KEY=
