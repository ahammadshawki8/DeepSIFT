# Copy to .env and fill in values — never commit .env to git

ANTHROPIC_API_KEY=your_key_here
VIRUSTOTAL_API_KEY=your_key_here
ABUSEIPDB_API_KEY=your_key_here

# Case directories (absolute paths on SIFT VM)
CASE_DIR=/cases
EXPORTS_DIR=./exports
ANALYSIS_DIR=./analysis

# SIFT tool paths (defaults match SIFT Workstation)
VOLATILITY_CMD=python3 -m volatility3
LOG2TIMELINE_CMD=log2timeline.py
PSORT_CMD=psort.py
FLS_CMD=fls
MMLS_CMD=mmls
ICAT_CMD=icat
YARA_CMD=yara
EZ_TOOLS_DIR=/opt/zimmermantools

# RAG settings
RAG_DB_PATH=./rag/db
EMBED_MODEL=all-MiniLM-L6-v2

# Execution limits
MAX_TOOL_TIMEOUT=300
MAX_ITERATIONS=10
